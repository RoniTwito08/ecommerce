# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=5000
FRONTEND_PORT=3000

# ─── MySQL ───────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=helfy
MYSQL_USER=helfy_user
MYSQL_PASSWORD=helfy_password

# ─── Backend – Database URL ───────────────────────────────────────────────────────
# Uses the Docker service name 'mysql' as the host inside the network.
# For local dev (no Docker), change 'mysql' to 'localhost'.
DATABASE_URL=mysql://helfy_user:helfy_password@mysql:3306/helfy

# ─── JWT ─────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-byte-hex-access-secret-do-not-use-in-production
JWT_REFRESH_SECRET=replace-with-64-byte-hex-refresh-secret-do-not-use-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Frontend ────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
