{
  "name": "helfy-backend",
  "version": "1.0.0",
  "description": "Helfy eCommerce Platform – REST API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
